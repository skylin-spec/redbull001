<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>testing</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, sans-serif;
      background: pink;
      color: #333;
      transition: background-color 0.6s ease;
    }

    body.blue-mode {
      background: #add8e6; /* light blue */
    }

    .section {
      min-height: 100vh;
      padding: 3rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ARTICLE PART */
    #article {
      text-align: center;
    }

    #article .content {
      max-width: 800px;
      font-size: 1.2rem;
      line-height: 1.6;
    }

    /* SIGN-UP SECTION */
    #signup {
      position: relative;
    }

    .signup-container {
      background: #add8e6; /* light blue rectangle container */
      border-radius: 16px;
      padding: 3rem 2rem;
      max-width: 600px;
      width: 90%;
      margin: 0 auto;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      transition:
        transform 0.6s ease,
        border-radius 0.6s ease,
        box-shadow 0.6s ease;
    }

    .yellow-box {
      background: #ffeb3b;
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
      transform: scale(1);
      transition: transform 0.6s ease;
    }

    .yellow-box h2 {
      margin-bottom: 1rem;
    }

    .yellow-box p {
      margin-bottom: 1.5rem;
    }

    .yellow-box form {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }

    .yellow-box input[type="email"] {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      border: 1px solid #aaa;
      min-width: 220px;
    }

    .yellow-box button {
      padding: 0.75rem 1.5rem;
      border-radius: 999px;
      border: none;
      background: #ff9800;
      color: #fff;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.3s ease, transform 0.2s ease;
    }

    .yellow-box button:hover {
      background: #fb8c00;
      transform: translateY(-1px);
    }

    /* When 50% of the signup section is in view */
    body.blue-mode .signup-container {
      position: fixed;
      inset: 0;
      margin: 0;
      border-radius: 0;
      max-width: 100%;
      width: 100%;
      height: 100%;
      box-shadow: none;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    body.blue-mode .yellow-box {
      transform: scale(1.3); /* enlarge */
    }
  </style>
</head>
<body>
  <!-- ARTICLE PART (one full screen) -->
  <section id="article" class="section">
    <div class="content">
      <h1>Article Part</h1>
      <p>
        This is the article section. Add any text you like here. The idea is that this
        fills up the first screen (one full page height), with a pink background.
      </p>
      <p>
        Scroll down to discover the sign up area. As you approach it, the page will
        transition from a pink background to light blue, and the sign up box will move
        into the center of the screen and enlarge.
      </p>
    </div>
  </section>

  <!-- SIGN-UP SECTION -->
  <section id="signup" class="section">
    <div class="signup-container">
      <div class="yellow-box">
        <h2>Sign up for free</h2>
        <p>Enter your email below and click submit.</p>
        <form>
          <input type="email" placeholder="Your email address" required />
          <button type="submit">Submit</button>
        </form>
      </div>
    </div>
  </section>

  <script>
    // When 50% of the sign-up section is visible, change to blue mode
    const signupSection = document.getElementById('signup');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.intersectionRatio >= 0.5) {
            document.body.classList.add('blue-mode');
          } else {
            document.body.classList.remove('blue-mode');
          }
        });
      },
      {
        threshold: [0.5],
      }
    );

    observer.observe(signupSection);
  </script>
</body>
</html>
